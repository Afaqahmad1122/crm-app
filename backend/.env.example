# Local Postgres (docker compose up -d): matches docker-compose.yml
DATABASE_URL=postgresql://postgres:password@localhost:5432/crm_db?schema=public
JWT_SECRET=
JWT_EXPIRES_IN=
PORT=3000
FRONTEND_ORIGIN=http://localhost:3000
# For cross-site auth cookies in production:
# AUTH_COOKIE_SAME_SITE=none
# AUTH_COOKIE_SECURE=true
# Optional if frontend/backend are on subdomains of one root domain:
# AUTH_COOKIE_DOMAIN=.example.com