# Local Postgres (docker compose up -d): matches docker-compose.yml
DATABASE_URL=postgresql://postgres:password@localhost:5432/crm_db?schema=public
JWT_SECRET=
# Short-lived access JWT (e.g. 15m). Refresh uses JWT_REFRESH_EXPIRES_IN.
JWT_EXPIRES_IN=15m
# Opaque refresh token lifetime (cookie + DB), e.g. 7d
JWT_REFRESH_EXPIRES_IN=7d
PORT=3000
# Global API rate limit (per IP): max requests per window
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
FRONTEND_ORIGIN=http://localhost:3000
# For cross-site auth cookies in production:
# AUTH_COOKIE_SAME_SITE=none
# AUTH_COOKIE_SECURE=true
# Optional if frontend/backend are on subdomains of one root domain:
# AUTH_COOKIE_DOMAIN=.example.com